# Personal AI Employee Configuration
# Copy this file to .env and fill in your values

# Claude API Configuration (if needed)
CLAUDE_API_KEY=

# Gemini API Configuration
GEMINI_API_KEY=

# Gmail IMAP Configuration (use Gmail App Password)
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=

# LinkedIn API Configuration
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# WhatsApp Configuration (if needed)
WHATSAPP_USERNAME=
WHATSAPP_PASSWORD=

# Filesystem Watcher Configuration
VAULT_PATH=./AI_Employee_Vault
INBOX_FOLDER=Inbox
NEEDS_ACTION_FOLDER=Needs_Action
DONE_FOLDER=Done
LOGS_FOLDER=Logs
PENDING_APPROVAL_FOLDER=Pending_Approval
APPROVED_FOLDER=Approved

# Application Settings
DRY_RUN=false
LOG_LEVEL=INFO

# Optional: PM2 Configuration
PM2_NAME=personal-ai-employee